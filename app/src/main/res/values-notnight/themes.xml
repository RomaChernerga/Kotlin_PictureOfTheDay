<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="DefaultTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primaryColorDEF</item>
        <item name="colorPrimaryVariant">@color/primaryLightColorDEF</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/secondaryColorDEF</item>
        <item name="colorSecondaryVariant">@color/secondaryLightColorDEF</item>
        <item name="colorOnSecondary">@color/primaryLightColorDEF</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
        <item name="textAppearanceButton">@style/AppTextAppearance.Button_Def</item>
        <item name="shapeAppearanceSmallComponent">@style/AppShapeAppearance.SmallComponent_Def</item>
        <item name="materialButtonStyle">@style/AppButtonDefault</item>
        <item name="textInputStyle">@style/AppTextFieldDefault</item>
        <item name="materialCardViewStyle">@style/AppCardDefault</item>.
        <item name="android:textColor">@color/black</item>
        <item name="android:panelColorBackground">#b0bec5</item>

    </style>


    <style name="RedTheme" parent="Theme.Design.Light.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primaryColorRED</item>
        <item name="colorPrimaryVariant">@color/primaryLightColorRED</item>
        <item name="colorOnPrimary">#ff6090</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">#e91e63</item>
        <item name="colorSecondaryVariant">#b0003a</item>
        !-- Customize your theme here. -->
        <item name="shapeAppearanceSmallComponent">@style/AppShapeAppearance.NewComponent</item>
        <item name="textAppearanceButton">@style/AppButtonRed</item>
        <item name="textInputStyle">@style/AppTextFieldDefault</item>
        <item name="materialCardViewStyle">@style/AppCardDefault</item>
        <item name="materialButtonStyle">@style/AppButtonRed</item>
        <item name="android:textColor">#83000000</item>
        <item name="android:colorBackground">#C4EA6565</item>


    </style>

    <style name="BlueTheme" parent="Theme.Design.Light.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">#035AF1</item>
        <item name="colorPrimaryVariant">#587CE6</item>
        <item name="colorOnPrimary">#600202</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">#587CE6</item>
        !-- Customize your theme here. -->
        <item name="textColorConnected">@color/purple_500</item>
        <item name="textAppearanceButton">@style/AppTextAppearance.Button_Def</item>
        <item name="shapeAppearanceSmallComponent">@style/AppShapeAppearance.NewComponent</item>
        <item name="materialButtonStyle">@style/AppButtonBlue</item>
        <item name="textInputStyle">@style/AppTextFieldDefault</item>
        <item name="materialCardViewStyle">@style/AppCardDefault</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:colorBackground">#C46D9EF1</item>

    </style>




</resources>