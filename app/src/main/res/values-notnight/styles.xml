<?xml version="1.0" encoding="utf-8"?>
<resources>


    <style name="AppTextAppearance.Button" parent="TextAppearance.MaterialComponents.Button">
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">14dp</item>
        <item name="fontFamily">sans-serif-light</item>
    </style>

    <style name="AppTextAppearance.ButtonCaps" parent="TextAppearance.MaterialComponents.Button">
        <item name="android:textAllCaps">true</item>
        <item name="android:typeface">serif</item>
        <item name="fontFamily">sans-serif-light</item>
    </style>


    <style name="AppShapeAppearance.SmallComponent" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">cut</item>
        <item name="cornerSize">8dp</item>
    </style>

    <style name="AppShapeAppearance.SmallComponentR" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerSize">10dp</item>
    </style>

    <style name="AppShapeAppearance.MediumComponent" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">10dp</item>
    </style>




    <style name="AppButtonBackDef" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/black</item>
    </style>

    <style name="AppButtonBackRed" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/white</item>
    </style>

    <style name="AppButtonBackBlue" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/colorAccent</item>
    </style>



    <style name="AppTextField" parent="Widget.MaterialComponents.TextInputLayout.FilledBox">
        <item name="boxBackgroundColor">@color/text_field_background</item>
    </style>

    <style name="AppTextFieldNew" parent="Widget.MaterialComponents.TextInputLayout.FilledBox">
        <item name="boxBackgroundColor">@color/text_field_background</item>
    </style>



    <style name="CardMediumShape" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerSize">12dp</item>
    </style>

    <style name="CardSmallShape" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerSize">9dp</item>
    </style>



    <style name="AppCard" parent="Widget.MaterialComponents.CardView">
        <item name="shapeAppearance">@style/CardMediumShape</item>
        <item name="cardElevation">8dp</item>
    </style>

    <style name="AppCardSmall" parent="Widget.MaterialComponents.CardView">
        <item name="shapeAppearance">@style/CardSmallShape</item>
        <item name="cardElevation">10dp</item>
    </style>




</resources>