<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="DefaultTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primaryDarkColorDEF</item>
        <item name="colorPrimaryVariant">@color/primaryColorDEF</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/secondaryDarkColorDEF</item>
        <item name="colorSecondaryVariant">@color/secondaryLightColorDEF</item>
        <!-- Customize your theme here. -->
        <item name="textAppearanceButton">@style/AppTextAppearance.Button_Def</item>
        <item name="shapeAppearanceSmallComponent">@style/AppShapeAppearance.NewComponent</item>
        <item name="shapeAppearanceMediumComponent">@style/AppShapeAppearance.NewComponent</item>
        <item name="materialButtonStyle">@style/AppButtonDefault</item>
        <item name="textInputStyle">@style/AppTextFieldDefault</item>
        <item name="materialCardViewStyle">@style/AppCardDefault</item>
    </style>


    <style name="RedTheme" parent="Theme.Design.Light.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primaryDarkColorRED</item>
        <item name="colorPrimaryVariant">@color/primaryDarkColorRED</item>
        <item name="colorOnPrimary">#F62F2F</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/secondaryDarkColorRED</item>
        <item name="colorSecondaryVariant">#b0003a</item>
        !-- Customize your theme here. -->
        <item name="shapeAppearanceSmallComponent">@style/AppShapeAppearance.NewComponent</item>
        <item name="textAppearanceButton">@style/AppButtonRed</item>
        <item name="materialCardViewStyle">@style/AppCardSmall</item>
        <item name="materialButtonStyle">@style/AppButtonRed</item>
        <item name="android:colorBackground">#B5B50404</item>
        <item name="android:textColor">@color/primaryTextColorRED</item>

    </style>

    <style name="BlueTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">#0029BF</item>
        <item name="colorPrimaryVariant">#2C51D8</item>
        <item name="colorOnPrimary">@color/black</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">#8B2970EA</item>
        !-- Customize your theme here. -->
        <item name="textColorConnected">@color/purple_500</item>
        <item name="textAppearanceButton">@style/AppTextAppearance.Button_Def</item>
        <item name="shapeAppearanceSmallComponent">@style/AppShapeAppearance.NewComponent</item>
        <item name="materialButtonStyle">@style/AppButtonBlue</item>
        <item name="textInputStyle">@style/AppTextFieldDefault</item>
        <item name="materialCardViewStyle">@style/AppCardDefault</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:colorBackground">#C46D9EF1</item>

    </style>



</resources>