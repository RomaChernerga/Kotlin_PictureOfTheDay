<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Текст на кнопках -->
    <style name="AppTextAppearance.Button_Def" parent="TextAppearance.MaterialComponents.Button">
        <item name="android:textAllCaps">false</item>
        <item name="fontFamily">sans-serif-light</item>
        <item name="android:typeface">sans</item>
    </style>

    <style name="AppTextAppearance.Button.TextStyleNew" parent="TextAppearance.MaterialComponents.Button">
        <item name="android:textAllCaps">true</item>
        <item name="android:typeface">serif</item>
        <item name="fontFamily">sans-serif-light</item>
    </style>

    <style name="AppShapeAppearance.SmallComponent_Def" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">10dp</item>
    </style>

    <style name="AppShapeAppearance.NewComponent" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerSize">10dp</item>
        <item name="cornerFamily">cut</item>
    </style>

    <style name="AppShapeAppearance.MediumComponent" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">10dp</item>
    </style>


    <!-- Стиль кнопок -->
    <style name="AppButtonDefault" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">#252525</item>
        <item name="android:textColor">#e2f1f8</item>
    </style>

    <style name="AppButtonRed" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/primaryColorRED</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">13sp</item>
        <item name="cornerRadius">8dp</item>
        <item name="rippleColor">#420303</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">#420303</item>
    </style>

    <style name="AppButtonBlue" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/primaryColorBLUE</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">13sp</item>
        <item name="cornerRadius">15dp</item>
        <item name="rippleColor">#032271</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">#032271</item>

    </style>



    <style name="AppTextFieldDefault" parent="Widget.MaterialComponents.TextInputLayout.FilledBox">
        <item name="boxBackgroundColor">@color/text_field_background</item>
    </style>


    <!-- Card View -->
    <style name="CardMediumShape" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerSize">12dp</item>
    </style>

    <style name="CardSmallShape" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerSize">9dp</item>
    </style>

    
    <style name="AppCardDefault" parent="Widget.MaterialComponents.CardView">
        <item name="shapeAppearance">@style/CardMediumShape</item>
        <item name="cardElevation">8dp</item>
        <item name="backgroundColor">@color/black</item>
    </style>

    <style name="AppCardSmall" parent="Widget.MaterialComponents.CardView">
        <item name="shapeAppearance">@style/CardSmallShape</item>
        <item name="cardElevation">10dp</item>
    </style>

</resources>